# Copy to .env on the server (do not commit real passwords)
#   cp .env.oracle.example .env
#   docker compose --env-file .env up -d --build

ORACLE_USER=your_schema_user
ORACLE_PASSWORD=your_password

# --- DSN-less (recommended): no tnsnames.ora, no ORACLE_DSN ---
ORACLE_HOST=dbhost.example.com
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=ORCLPDB1
    #   - ${PNG_EXPORT_HOST_PATH:-./exports}:/exports
    #   # Example Forms images path (optional):
    #   # - /home/oracle/product/fmw14.1.2/forms/images:/exports

# --- Or use Easy Connect string instead (leave HOST empty) ---
# ORACLE_DSN=dbhost.example.com:1521/ORCLPDB1

ORACLE_TABLE=port_containers
PNG_EXPORT_HOST_PATH=./exports
